# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/creator-os

# OpenAI
OPENAI_API_KEY=sk-...

# Voyage AI (for embeddings)
VOYAGE_API_KEY=pa-...

# YouTube Data API (for news research - viral/trending videos)
# Get from Google Cloud Console: APIs & Services > Credentials > Create API Key
# Enable "YouTube Data API v3" for the project
YOUTUBE_API_KEY=your-youtube-api-key

# NextAuth
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth (for NextAuth)
GITHUB_ID=your-github-app-id
GITHUB_SECRET=your-github-app-secret
